# 环境变量配置

# 服务端口配置
PORT=18081
# 开发时 Vite 常用 18080；经 Docker Nginx 用 http://localhost（80）打开时 Origin 不同，网关已默认放行 http://localhost / http://127.0.0.1
FRONTEND_URL=http://localhost:18080

# CORS：部署到云服务器时，用浏览器打开「http://公网IP」访问前端时，POST 等请求会带该 Origin。
# 若未在下面填写，网关会返回 403（CORS policy violation）。多个地址用英文逗号分隔，不要有空格。
# 示例（Docker 默认宿主端口 8081，勿将真实地址长期写进仓库）：CORS_EXTRA_ORIGINS=http://YOUR_PUBLIC_IP:8081,http://YOUR_PUBLIC_IP
CORS_EXTRA_ORIGINS=

# 微服务地址配置
AD_CAMPAIGN_URL=http://localhost:18889
VIDEO_GENERATION_URL=http://localhost:19000

# 环境模式
NODE_ENV=development

# 日志配置
LOG_LEVEL=info

# 文件上传配置
MAX_FILE_SIZE=100MB
UPLOAD_PATH=./uploads

# video-service：VideoGenerator 所在目录（可选；默认使用仓库内 video-service/vendor/ffmpeg）
# VIDEO_GENERATOR_DIR=

# Docker 拼图：与 api-gateway 共享 temp 卷时由 compose 注入，勿手动改
# STITCH_TEMP_DIR=/app/public/temp

# 拼图「生成并上传外链」：imgfi.com 图床（可选；不配则本地拼接成功，上传步骤会提示 API Key 无效）
# 在 imgfi 控制台创建 API Key；勿把密钥提交到 Git
# IMGFI_UPLOAD_URL=https://imgfi.com/api/1/upload
# IMGFI_API_KEY=

# 数据库配置（如果需要）
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ronghe_platform
# DB_USER=your_username
# DB_PASSWORD=your_password

# Redis配置（如果需要缓存）
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# 安全配置
SECRET_KEY=your-secret-key-here
JWT_SECRET=your-jwt-secret-here

# 邮件配置（如果需要通知功能）
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
